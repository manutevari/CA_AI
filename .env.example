# Copy to `.env` and adjust. Never commit real secrets.

APP_NAME=TaxPilot AI
ENVIRONMENT=development

DATABASE_URL=postgresql+psycopg://taxpilot:taxpilot@localhost:5432/taxpilot
REDIS_URL=redis://localhost:6379/0

SECRET_KEY=change-me-use-long-random
JWT_SECRET=change-me-jwt-secret
# Fernet key (44 chars). Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional dynamic agent providers for the Streamlit filing lab.
# Streamlit Cloud users should put these in app secrets instead of this file.
TAVILY_KEY=
tavily_key=
HF_API_KEY=
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HF_CHAT_ENDPOINT=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=
S3_ENDPOINT_URL=

STORAGE_LOCAL_PATH=./data/uploads

CORS_ORIGINS=http://localhost:3000
